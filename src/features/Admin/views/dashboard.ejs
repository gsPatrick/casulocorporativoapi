<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Casulo B2B | Gestão de Orçamentos</title>
    <link rel="stylesheet" href="https://unpkg.com/@shopify/polaris@12.0.0/build/esm/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@shopify/app-bridge@3.7.10/umd/index.js"></script>
    <script src="https://unpkg.com/@shopify/app-bridge-utils@3.4.3/umd/index.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        const AppBridge = window['app-bridge'];
        const createApp = AppBridge.default;
        const app = createApp({
            apiKey: '<%= apiKey %>',
            host: '<%= host %>',
            forceRedirect: true
        });
    </script>
    <style>
        :root {
            --p-color-bg: #ffffff;
            --p-color-text: #000000;
            --p-color-border: #eeeeee;
            --p-color-accent: #000000;
        }

        body { 
            background-color: #fff; 
            color: #000;
            padding: 30px; 
            font-family: 'Inter', -apple-system, sans-serif; 
            -webkit-font-smoothing: antialiased;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 2px solid #000;
        }

        .header h1 {
            font-size: 24px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: -0.5px;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .polaris-card { 
            background: white; 
            border: 1px solid #eee;
            border-radius: 0;
            padding: 0; 
            margin-bottom: 20px; 
        }

        table { width: 100%; border-collapse: collapse; }
        th { 
            text-align: left; 
            padding: 16px 20px; 
            border-bottom: 1px solid #000; 
            color: #000; 
            font-size: 11px; 
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }
        td { 
            padding: 16px 20px; 
            border-bottom: 1px solid #eee; 
            font-size: 13px; 
            color: #333; 
            vertical-align: middle;
        }

        .row-main:hover { background-color: #fafafa; cursor: pointer; }
        
        .status-badge { 
            padding: 4px 10px; 
            border-radius: 2px; 
            font-size: 10px; 
            font-weight: 700; 
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 1px solid #000;
        }
        .status-pendente { background: #fff; color: #000; border-color: #ccc; }
        .status-aprovado { background: #000; color: #fff; border-color: #000; }
        .status-cancelado { background: #eee; color: #999; border-color: #eee; }

        .btn-black { 
            background: #000; 
            color: #fff; 
            border: 1px solid #000;
            padding: 8px 16px; 
            border-radius: 2px; 
            cursor: pointer; 
            font-size: 11px; 
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
        }
        .btn-black:hover { background: #333; transform: translateY(-1px); }
        .btn-outline { background: transparent; color: #000; }
        .btn-outline:hover { background: #f5f5f5; }

        /* Expandable Row */
        .edit-row { display: none; background-color: #fcfcfc; }
        .edit-inner { padding: 30px; border-bottom: 1px solid #eee; }
        
        .product-edit-card {
            display: flex;
            gap: 20px;
            background: #fff;
            border: 1px solid #eee;
            padding: 15px;
            margin-bottom: 15px;
            align-items: center;
        }
        .product-img { width: 80px; height: 80px; object-fit: cover; border: 1px solid #eee; background: #f9f9f9; }
        .product-form { flex: 1; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 15px; }
        
        .input-premium {
            border: 1px solid #ddd;
            padding: 10px;
            font-size: 13px;
            width: 100%;
            border-radius: 0;
            font-family: inherit;
        }
        .input-premium:focus { border-color: #000; outline: none; }
        
        .label-premium { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #999; margin-bottom: 5px; display: block; }

        .summary-box {
            margin-top: 20px;
            padding: 20px;
            background: #f1f1f1;
            text-align: right;
            font-weight: 700;
        }
        
        .lucide { width: 16px; height: 16px; }
    </style>
</head>
<body>
    <div class="header">
        <h1><i data-lucide="package"></i> Painel de Orçamentos</h1>
        <div style="display: flex; gap: 10px;">
            <div style="position: relative;">
                <i data-lucide="search" style="position: absolute; left: 10px; top: 10px; color: #999;"></i>
                <input type="text" id="search-input" placeholder="BUSCAR NOME, EMAIL, REF..." 
                       style="padding: 10px 10px 10px 35px; border: 1px solid #000; font-size: 12px; width: 250px;" 
                       onkeyup="applyFilters()">
            </div>
            <button class="btn-black btn-outline" onclick="toggleFilters()"><i data-lucide="filter"></i> Filtros</button>
        </div>
    </div>

    <!-- PAINEL DE FILTROS -->
    <div id="filter-panel" style="display: none; background: #fafafa; border: 1px solid #eee; padding: 20px; margin-bottom: 20px; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px;">
        <div>
            <label class="label-premium">Status</label>
            <select id="filter-status" class="input-premium" onchange="applyFilters()">
                <option value="all">Todos os Status</option>
                <option value="pendente">Pendente</option>
                <option value="aprovado">Aprovado</option>
                <option value="cancelado">Cancelado</option>
            </select>
        </div>
        <div>
            <label class="label-premium">Tipo de Cliente</label>
            <select id="filter-customer" class="input-premium" onchange="applyFilters()">
                <option value="all">Todos os Tipos</option>
                <option value="logado">Logado (Cadastrado)</option>
                <option value="convidado">Convidado (Lead)</option>
            </select>
        </div>
        <div>
            <label class="label-premium">Regra de Desconto</label>
            <select id="filter-category" class="input-premium" onchange="applyFilters()">
                <option value="all">Todas as Regras</option>
                <option value="Cliente Novo">Cliente Novo (10%)</option>
                <option value="Cliente Ocasional">Cliente Ocasional (15%)</option>
                <option value="Cliente Recorrente">Cliente Recorrente (20%)</option>
                <option value="Desconto Manual">Desconto Manual</option>
                <option value="none">Sem Desconto</option>
            </select>
        </div>
        <div style="display: flex; align-items: flex-end;">
            <button class="btn-black btn-outline" style="width: 100%; height: 38px;" onclick="resetFilters()">Limpar Filtros</button>
        </div>
    </div>

    <div class="polaris-card">
        <table>
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Ref</th>
                    <th>Cliente / Empresa</th>
                    <th>Vendedor</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th style="text-align: right;">Ações</th>
                </tr>
            </thead>
            <tbody>
                <% orcamentos.forEach(orc => { %>
                    <tr class="row-main budget-row" 
                        onclick="toggleEdit('<%= orc.id %>')"
                        data-status="<%= orc.status %>"
                        data-customer="<%= orc.customer_type || 'convidado' %>"
                        data-category="<%= orc.discount_category || 'none' %>"
                        data-search="<%= (orc.customer_name || '').toLowerCase() %> <%= (orc.customer_email || '').toLowerCase() %> <%= (orc.id || '').substring(0,8).toLowerCase() %> <%= (orc.vendedor || '').toLowerCase() %> <%= (orc.customer_tags || []).join(' ').toLowerCase() %> <%= (orc.lead_json?.empresa || '').toLowerCase() %> <%= (orc.lead_json?.cep || '').toLowerCase() %>"
                    >
                        <td style="font-weight: 500;"><%= new Date(orc.createdAt).toLocaleDateString('pt-BR') %></td>
                        <td style="font-family: monospace; font-size: 11px;"><%= orc.id.substring(0,8).toUpperCase() %></td>
                        <td>
                            <div style="font-weight: 700; text-transform: uppercase;">
                                <%= orc.customer_name %>
                                <% if (orc.lead_json?.empresa) { %>
                                    <span style="font-weight: 400; color: #666; font-size: 11px;"> - <%= orc.lead_json.empresa %></span>
                                <% } %>
                            </div>
                            <div style="font-size: 11px; color: #888;">
                                <%= orc.customer_email || 'n/a' %>
                                <% if (orc.lead_json?.cep) { %>
                                    <span style="margin-left: 8px; color: #aaa;">CEP: <%= orc.lead_json.cep %></span>
                                <% } %>
                            </div>
                            <div style="margin-top: 4px; display: flex; gap: 4px;">
                                <span class="status-badge" style="font-size: 9px; padding: 2px 6px;">
                                    <%= orc.customer_type || 'convidado' %>
                                </span>
                                <% if (orc.discount_category) { %>
                                    <span class="status-badge" style="font-size: 9px; padding: 2px 6px; background: #e3f2fd; color: #1976d2; border: 1px solid #bbdefb;">
                                        <%= orc.discount_category %>
                                    </span>
                                <% } %>
                            </div>
                            <div style="margin-top: 6px; display: flex; gap: 4px; flex-wrap: wrap;">
                                <% (orc.customer_tags || []).forEach(tag => { %>
                                    <span style="font-size: 9px; color: #666; background: #f9f9f9; border: 1px solid #eee; padding: 1px 4px; border-radius: 2px;"><%= tag %></span>
                                <% }); %>
                            </div>
                        </td>
                        <td><%= orc.vendedor || '-' %></td>
                        <td>
                            <span class="status-badge status-<%= orc.status %>" id="badge-<%= orc.id %>">
                                <%= orc.status %>
                            </span>
                        </td>
                        <td style="font-weight: 800;" id="display-total-<%= orc.id %>">
                            R$ <%= parseFloat(orc.total_price).toFixed(2).replace('.', ',') %>
                        </td>
                        <td style="text-align: right;">
                            <div style="display: inline-flex; gap: 10px;">
                                <a href="/api/orcamento/<%= orc.id %>/pdf" target="_blank" class="btn-black btn-outline" onclick="event.stopPropagation()">
                                    <i data-lucide="file-text"></i> PDF
                                </a>
                                <% if (orc.status === 'pendente') { %>
                                    <button onclick="changeStatus('<%= orc.id %>', 'aprovado'); event.stopPropagation();" class="btn-black" id="btn-approve-<%= orc.id %>">
                                        <i data-lucide="check"></i> Aprovar
                                    </button>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <!-- Row de Edição -->
                    <tr class="edit-row" id="edit-row-<%= orc.id %>">
                        <td colspan="7">
                            <div class="edit-inner">
                                <h3 style="font-size: 14px; font-weight: 700; margin-bottom: 20px; text-transform: uppercase; display: flex; align-items: center; gap: 8px;">
                                    <i data-lucide="edit-3"></i> Detalhes e Edição do Orçamento
                                </h3>

                                <% if (orc.lead_json) { %>
                                    <div style="background: #fff; border: 1px solid #e3e3e3; padding: 15px; border-radius: 4px; margin-bottom: 20px; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                                        <div>
                                            <label class="label-premium" style="font-size: 10px; color: #999;">Solicitante</label>
                                            <div style="font-weight: 600;"><%= orc.customer_name %></div>
                                        </div>
                                        <div>
                                            <label class="label-premium" style="font-size: 10px; color: #999;">WhatsApp</label>
                                            <div style="font-weight: 600;"><%= orc.customer_phone || 'Não informado' %></div>
                                        </div>
                                        <div>
                                            <label class="label-premium" style="font-size: 10px; color: #999;">Empresa</label>
                                            <div style="font-weight: 600;"><%= orc.lead_json.empresa || 'Não informado' %></div>
                                        </div>
                                        <div>
                                            <label class="label-premium" style="font-size: 10px; color: #999;">CEP</label>
                                            <div style="font-weight: 600;"><%= orc.lead_json.cep || 'Não informado' %></div>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <form id="form-<%= orc.id %>" onsubmit="saveOrcamento('<%= orc.id %>'); return false;">
                                    <% orc.line_items_json.forEach((item, idx) => { %>
                                        <div class="product-edit-card">
                                            <img src="<%= item.custom_image || 'https://via.placeholder.com/100' %>" class="product-img" onerror="this.src='https://via.placeholder.com/100'">
                                            <div class="product-form" style="display: block;">
                                                <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                                                    <div>
                                                        <label class="label-premium">Nome do Produto</label>
                                                        <input type="text" name="items[<%= idx %>][title]" value="<%= item.title %>" class="input-premium">
                                                    </div>
                                                    <div>
                                                        <label class="label-premium">Preço Unitário (R$)</label>
                                                        <input type="text" name="items[<%= idx %>][price]" value="<%= parseFloat(item.price || 0).toFixed(2).replace('.', ',') %>" 
                                                               class="input-premium item-price-input money-mask" data-orc-id="<%= orc.id %>" oninput="recalcTotal('<%= orc.id %>')">
                                                    </div>
                                                    <div>
                                                        <label class="label-premium">Qtd</label>
                                                        <input type="number" value="<%= item.quantity || 1 %>" disabled class="input-premium item-qty-input" style="background: #f9f9f9; color: #999;">
                                                    </div>
                                                </div>
                                                <div>
                                                    <label class="label-premium">Descrição Técnica / Especificação</label>
                                                    <textarea name="items[<%= idx %>][technical_specification]" class="input-premium" rows="3" style="resize: vertical; font-size: 12px;"><%= item.technical_specification %></textarea>
                                                </div>
                                                <% if (item.configuration_url) { %>
                                                    <div style="margin-top: 10px;">
                                                        <a href="<%= item.configuration_url %>" target="_blank" style="font-size: 10px; color: #000; text-decoration: underline; display: inline-flex; align-items: center; gap: 4px;">
                                                            <i data-lucide="external-link" style="width: 12px; height: 12px;"></i> REABRIR NO CUSTOMIZADOR
                                                        </a>
                                                    </div>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }); %>

                                    <div class="summary-box" style="text-align: left; background: #fafafa; border: 1px solid #ddd;">
                                        <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 30px;">
                                            <div>
                                                <label class="label-premium">Regra de Desconto / Categoria</label>
                                                <select name="discount_type" class="input-premium" style="margin-bottom: 15px;" onchange="toggleManualDiscount('<%= orc.id %>')">
                                                    <option value="none" <%= (!orc.discount_category) ? 'selected' : '' %>>Sem Desconto (0%)</option>
                                                    <option value="novo" <%= (orc.discount_category === 'Cliente Novo') ? 'selected' : '' %>>Cliente Novo (10%)</option>
                                                    <option value="ocasional" <%= (orc.discount_category === 'Cliente Ocasional') ? 'selected' : '' %>>Cliente Ocasional (15%)</option>
                                                    <option value="recorrente" <%= (orc.discount_category === 'Cliente Recorrente') ? 'selected' : '' %>>Cliente Recorrente (20%)</option>
                                                    <option value="manual_percent" <%= (orc.discount_category === 'Desconto Manual (%)') ? 'selected' : '' %>>Desconto Manual (%)</option>
                                                    <option value="manual_fixed" <%= (orc.discount_category === 'Desconto Manual (R$)') ? 'selected' : '' %>>Desconto Manual (Valor Fixo R$)</option>
                                                </select>
                                                
                                                <div id="manual-discount-container-<%= orc.id %>" style="display: <%= (orc.discount_category && orc.discount_category.includes('Manual')) ? 'block' : 'none' %>;">
                                                    <label class="label-premium">Valor do Desconto</label>
                                                    <input type="text" name="discount_value" value="<%= parseFloat(orc.discount_amount || 0).toFixed(2).replace('.', ',') %>" 
                                                           class="input-premium money-mask" oninput="recalcTotal('<%= orc.id %>')">
                                                </div>
                                            </div>
                                            <div style="text-align: right; border-left: 1px solid #eee; padding-left: 20px;">
                                                <div style="font-size: 11px; color: #666; margin-bottom: 5px;">
                                                    SUBTOTAL ITENS: <span id="subtotal-val-<%= orc.id %>">R$ <%= parseFloat(orc.original_price || orc.total_price).toFixed(2).replace('.', ',') %></span>
                                                </div>
                                                <div style="font-size: 11px; color: #d32f2f; margin-bottom: 5px;" id="discount-display-container-<%= orc.id %>">
                                                    DESCONTO: - <span id="discount-val-<%= orc.id %>">R$ <%= parseFloat(orc.discount_amount || 0).toFixed(2).replace('.', ',') %></span>
                                                </div>
                                                <div style="font-weight: 800; font-size: 14px; margin-top: 10px; color: #000;">
                                                    TOTAL LÍQUIDO: <br>
                                                    <span style="font-size: 22px;" id="recalc-total-<%= orc.id %>">
                                                        R$ <%= parseFloat(orc.total_price).toFixed(2).replace('.', ',') %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div style="display: flex; justify-content: flex-end; gap: 15px; margin-top: 20px;">
                                        <button type="button" class="btn-black btn-outline" onclick="toggleEdit('<%= orc.id %>')">Cancelar</button>
                                        <button type="submit" class="btn-black" id="btn-save-<%= orc.id %>">
                                            <i data-lucide="save"></i> Salvar e Atualizar PDF
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <script>
        lucide.createIcons();
        
        async function getAuthenticatedToken() {
            try {
                if (window.shopify && typeof window.shopify.idToken === 'function') {
                    return await window.shopify.idToken();
                }
                const urlParams = new URLSearchParams(window.location.search);
                const idToken = urlParams.get('id_token') || urlParams.get('session');
                return idToken;
            } catch (err) {
                console.error('[AUTH ERROR]:', err);
                return new URLSearchParams(window.location.search).get('id_token');
            }
        }

        function toggleEdit(id) {
            const row = document.getElementById(`edit-row-${id}`);
            const isVisible = row.style.display === 'table-row';
            document.querySelectorAll('.edit-row').forEach(r => r.style.display = 'none');
            if (!isVisible) row.style.display = 'table-row';
        }

        // --- SISTEMA DE FILTROS ---
        function toggleFilters() {
            const panel = document.getElementById('filter-panel');
            panel.style.display = panel.style.display === 'none' ? 'grid' : 'none';
        }

        function resetFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('filter-status').value = 'all';
            document.getElementById('filter-customer').value = 'all';
            document.getElementById('filter-category').value = 'all';
            applyFilters();
        }

        function applyFilters() {
            const searchText = document.getElementById('search-input').value.toLowerCase();
            const filterStatus = document.getElementById('filter-status').value;
            const filterCustomer = document.getElementById('filter-customer').value;
            const filterCategory = document.getElementById('filter-category').value;

            const rows = document.querySelectorAll('.budget-row');
            
            rows.forEach(row => {
                const searchData = row.getAttribute('data-search');
                const rowStatus = row.getAttribute('data-status');
                const rowCustomer = row.getAttribute('data-customer');
                const rowCategory = row.getAttribute('data-category');

                const matchesSearch = searchData.includes(searchText);
                const matchesStatus = filterStatus === 'all' || rowStatus === filterStatus;
                const matchesCustomer = filterCustomer === 'all' || rowCustomer === filterCustomer;
                const matchesCategory = filterCategory === 'all' || rowCategory.includes(filterCategory) || (filterCategory === 'none' && rowCategory === 'none');

                if (matchesSearch && matchesStatus && matchesCustomer && matchesCategory) {
                    row.style.display = 'table-row';
                } else {
                    row.style.display = 'none';
                    // Se estiver com edição aberta para esta linha, fechar ela também
                    const id = row.getAttribute('onclick').match(/'([\w-]+)'/)[1];
                    const editRow = document.getElementById(`edit-row-${id}`);
                    if (editRow) editRow.style.display = 'none';
                }
            });
        }

        function recalcTotal(id) {
            const form = document.getElementById(`form-${id}`);
            const priceInputs = form.querySelectorAll('.item-price-input');
            const qtyInputs = form.querySelectorAll('.item-qty-input');
            const discountType = form.querySelector('[name="discount_type"]').value;
            const discountValueInput = form.querySelector('[name="discount_value"]');

            let subtotal = 0;
            priceInputs.forEach((input, idx) => {
                const cleaned = input.value.replace(/\./g, '').replace(',', '.');
                const price = parseFloat(cleaned) || 0;
                const qty = parseInt(qtyInputs[idx].value) || 1;
                subtotal += price * qty;
            });

            let discountAmount = 0;
            if (discountType === 'novo') discountAmount = subtotal * 0.10;
            else if (discountType === 'ocasional') discountAmount = subtotal * 0.15;
            else if (discountType === 'recorrente') discountAmount = subtotal * 0.20;
            else if (discountType === 'manual_percent') {
                const pct = parseFloat(discountValueInput.value.replace(',', '.')) || 0;
                discountAmount = subtotal * (pct / 100);
            } else if (discountType === 'manual_fixed') {
                const cleaned = discountValueInput.value.replace(/\./g, '').replace(',', '.');
                discountAmount = parseFloat(cleaned) || 0;
            }

            const total = subtotal - discountAmount;

            document.getElementById(`subtotal-val-${id}`).innerText = subtotal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById(`discount-val-${id}`).innerText = discountAmount.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            document.getElementById(`recalc-total-${id}`).innerText = total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function toggleManualDiscount(id) {
            const form = document.getElementById(`form-${id}`);
            const type = form.querySelector('[name="discount_type"]').value;
            const container = document.getElementById(`manual-discount-container-${id}`);
            if (type.startsWith('manual')) {
                container.style.display = 'block';
            } else {
                container.style.display = 'none';
            }
            recalcTotal(id);
        }

        // MÁSCARA DE MOEDA (R$)
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('money-mask')) {
                let value = e.target.value.replace(/\D/g, '');
                value = (value / 100).toFixed(2) + '';
                value = value.replace(".", ",");
                const parts = value.split(',');
                parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ".");
                e.target.value = parts.join(',');
                
                const orcId = e.target.getAttribute('data-orc-id') || e.target.closest('form')?.onsubmit?.toString().match(/'([\w-]+)'/)[1];
                if (orcId) recalcTotal(orcId);
            }
        });

        async function saveOrcamento(id) {
            const btn = document.getElementById(`btn-save-${id}`);
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader" class="animate-spin"></i> SALVANDO...';
            lucide.createIcons();

            const form = document.getElementById(`form-${id}`);
            const priceInputs = form.querySelectorAll('.item-price-input');
            const titleInputs = form.querySelectorAll('input[name*="[title]"]');
            const specInputs = form.querySelectorAll('textarea[name*="[technical_specification]"]');
            const discountType = form.querySelector('[name="discount_type"]').value;
            const discountValue = form.querySelector('[name="discount_value"]').value;

            const items = [];
            priceInputs.forEach((input, idx) => {
                items.push({
                    title: titleInputs[idx].value,
                    price: input.value,
                    technical_specification: specInputs[idx].value
                });
            });

            try {
                const token = await getAuthenticatedToken();
                const response = await fetch(`${window.location.origin}/admin/orcamento/${id}/update`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ items, discount_type: discountType, discount_value: discountValue })
                });

                if (response.ok) {
                    const result = await response.json();
                    document.getElementById(`display-total-${id}`).innerText = result.total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                    alert('Orçamento atualizado e novo PDF enviado ao cliente!');
                    toggleEdit(id);
                } else {
                    alert('Erro ao salvar orçamento.');
                }
            } catch (err) {
                alert(`Erro: ${err.message}`);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
                lucide.createIcons();
            }
        }

        async function changeStatus(id, newStatus) {
            const badge = document.getElementById(`badge-${id}`);
            if (!confirm(`Deseja alterar para "${newStatus}"?`)) return;
            try {
                const token = await getAuthenticatedToken();
                const response = await fetch(`${window.location.origin}/admin/orcamento/${id}/status`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ status: newStatus })
                });
                if (response.ok) {
                    badge.innerText = newStatus;
                    badge.className = `status-badge status-${newStatus}`;
                    alert('Status atualizado!');
                }
            } catch (err) {
                alert(`Erro: ${err.message}`);
            }
        }
    </script>
</body>
</html>
