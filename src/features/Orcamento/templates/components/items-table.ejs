<table style="width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 11px;">
    <thead>
        <tr style="background-color: #f9f9f9; border-bottom: 1px solid #ddd; text-align: left;">
            <th style="padding: 10px; border: 1px solid #ddd; width: 260px; text-align: center;">Produto</th>
            <th style="padding: 10px; border: 1px solid #ddd;">Descrição do produto/serviço</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 40px; text-align: center;">Qtd.</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 80px; text-align: right;">Preço un.</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 80px; text-align: right;">Preço total</th>
        </tr>
    </thead>
    <tbody>
        <% items.forEach((item, index) => { %>
            <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px; border: 1px solid #ddd; text-align: center; vertical-align: top;">
                    <% if (item.custom_image_base64) { %>
                        <img src="data:image/png;base64,<%= item.custom_image_base64 %>" style="width: 240px; height: auto; border: 1px solid #eee; border-radius: 4px;">
                    <% } else { %>
                        <div style="width: 240px; height: 240px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 8px; color: #999; border-radius: 4px;">Sem imagem</div>
                    <% } %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; vertical-align: top;">
                    <div style="font-weight: bold; font-size: 13px; margin-bottom: 5px; color: #333;">
                        <%= item.title %>
                    </div>
                    <div style="font-size: 10px; color: #666; line-height: 1.5; text-align: justify;">
                        <%= item.technical_specification.replace(/\n/g, ', ') %>
                    </div>
                    <% if (item.additional_info && item.additional_info.trim() !== '') { %>
                        <div style="margin-top: 8px; padding-top: 8px; border-top: 1px dashed #eee; font-size: 10px; color: #444;">
                            <strong style="color: #814620;">Info Adicional:</strong> <br>
                            <%- item.additional_info.replace(/\n/g, '<br>') %>
                        </div>
                    <% } %>
                    <% if (item.configuration_url) { %>
                        <div style="margin-top: 8px;">
                            <a href="<%= item.configuration_url %>" style="color: #814620; text-decoration: none; font-weight: bold; font-size: 10px; border-bottom: 1px solid #814620;">[Ver Configuração 3D]</a>
                        </div>
                    <% } %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: center; vertical-align: top;">
                    <%= item.quantity %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: right; vertical-align: top; color: #555;">
                    <%= item.unit_price_formatted %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: right; vertical-align: top; font-weight: bold;">
                    <%= item.total_price_formatted %>
                </td>
            </tr>
        <% }); %>
    </tbody>
</table>
<div style="margin-top: 20px; text-align: right; font-size: 11px; color: #666;">
    Subtotal: <%= original_formatted %><br>
    <div style="margin-top: 10px; font-size: 16px; color: #000;">
        <strong>Total da Proposta: <%= total_formatted %></strong>
    </div>
</div>
