<table style="width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 11px;">
    <thead>
        <tr style="background-color: #f9f9f9; border-bottom: 1px solid #ddd; text-align: left;">
            <th style="padding: 10px; border: 1px solid #ddd; width: 260px; text-align: center;">Produto</th>
            <th style="padding: 10px; border: 1px solid #ddd;">Descrição do produto/serviço</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 40px; text-align: center;">Qtd.</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 80px; text-align: right;">Preço un.</th>
            <th style="padding: 10px; border: 1px solid #ddd; width: 80px; text-align: right;">Preço total</th>
        </tr>
    </thead>
    <tbody>
        <% items.forEach((item, index) => { %>
            <tr style="border-bottom: 1px solid #eee;">
                <td style="padding: 10px; border: 1px solid #ddd; text-align: center; vertical-align: middle; background: #ffffff;">
                    <% if (item.custom_image_base64) { %>
                        <div style="width: 240px; height: 240px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #ffffff;">
                            <img src="data:image/png;base64,<%= item.custom_image_base64 %>" style="max-width: 100%; max-height: 100%; object-fit: contain; border: none;">
                        </div>
                    <% } else { %>
                        <div style="width: 240px; height: 240px; background: #ffffff; display: flex; align-items: center; justify-content: center; font-size: 8px; color: #ccc;">Sem imagem</div>
                    <% } %>
                </td>
                <td style="padding: 15px; border: 1px solid #ddd; vertical-align: top;">
                    <div style="font-weight: bold; font-size: 13px; margin-bottom: 8px; color: #000; text-transform: uppercase;">
                        <%= item.title %>
                    </div>
                    
                    <ul style="margin: 0; padding-left: 15px; font-size: 10px; color: #555; line-height: 1.4;">
                        <% (item.technical_specification || '').split('\n').filter(s => s.trim() !== '').forEach(spec => { %>
                            <li style="margin-bottom: 3px;"><%= spec.trim() %></li>
                        <% }); %>
                    </ul>

                    <% if (item.additional_info && item.additional_info.trim() !== '') { %>
                        <div style="margin-top: 10px; padding-top: 8px; border-top: 1px dashed #eee; font-size: 9px; color: #777;">
                            <strong style="color: #000; text-transform: uppercase; font-size: 8px;">Observações:</strong> <br>
                            <%- item.additional_info.replace(/\n/g, '<br>') %>
                        </div>
                    <% } %>
                    <% if (item.configuration_url) { %>
                        <div style="margin-top: 10px;">
                            <a href="<%= item.configuration_url %>" style="color: #000; text-decoration: underline; font-weight: bold; font-size: 9px; text-transform: uppercase;">[Ver Reconfiguração 3D]</a>
                        </div>
                    <% } %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: center; vertical-align: top;">
                    <%= item.quantity %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: right; vertical-align: top; color: #555;">
                    <%= item.unit_price_formatted %>
                </td>
                <td style="padding: 10px; border: 1px solid #ddd; text-align: right; vertical-align: top; font-weight: bold;">
                    <%= item.total_price_formatted %>
                </td>
            </tr>
        <% }); %>
    </tbody>
</table>
<div style="margin-top: 20px; text-align: right; font-size: 11px; color: #666;">
    <div style="margin-top: 10px; font-size: 16px; color: #000;">
        <strong>Total da Proposta: <%= total_formatted %></strong>
    </div>
</div>
