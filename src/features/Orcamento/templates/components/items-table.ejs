<div style="margin-top: 0;">
    <% 
    let currentCategory = null; 
    items.forEach((item, index) => { 
        if (item.category && item.category !== currentCategory) { 
            currentCategory = item.category;
    %>
        <div style="border-bottom: 2px solid #000; padding: 2px 0; margin-top: 8px; margin-bottom: 3px; display: flex; justify-content: space-between; align-items: baseline;">
            <span style="font-size: 10px; font-weight: bold; text-transform: uppercase;"><%= currentCategory %></span>
            <span style="font-size: 7px; color: #999;">AMBIENTE</span>
        </div>
    <% } %>

        <div style="margin-bottom: 5px; page-break-inside: avoid; break-inside: avoid;">
            <div style="border-top: 1px solid #eee; padding: 2px 0; display: flex; align-items: center; margin-bottom: 3px;">
                <div style="width: 40px; font-size: 8px; color: #666; font-weight: bold;">
                    #<%= (index + 1).toString().padStart(3, '0') %>
                </div>
                <div style="flex: 1; font-size: 10px; font-weight: bold; text-transform: uppercase;">
                    <%= item.title %>
                </div>
                <% if (item.legend_id) { %>
                    <div style="border: 1px solid #000; padding: 0px 4px; font-size: 7px; font-weight: bold;"><%= item.legend_id %></div>
                <% } %>
            </div>

            <div style="display: flex; align-items: flex-start; gap: 15px;">
                <div style="flex: 0 0 95px; width: 95px; height: 95px; border: 1px solid #f9f9f9; display: flex; align-items: center; justify-content: center;">
                    <% if (item.custom_image_base64) { %>
                        <img src="data:image/png;base64,<%= item.custom_image_base64 %>" style="max-width: 95%; max-height: 95%; width: auto; height: auto; display: block; object-fit: contain;">
                    <% } else { %>
                        <div style="font-size: 6px; color: #ccc;">S/IMG</div>
                    <% } %>
                </div>

                <div style="flex: 1;">
                    <div style="font-size: 9px; line-height: 1.2; margin-bottom: 3px;">
                        <% if (item.technical_specification) { %>
                            <% item.technical_specification.split('\n').filter(line => line.trim()).forEach(line => { %>
                                <div style="margin-bottom: 1px;">• <%= line.trim() %></div>
                            <% }); %>
                        <% } %>
                    </div>

                    <div style="border-top: 1px dashed #f5f5f5; padding-top: 2px; display: flex; align-items: baseline; gap: 10px;">
                        <div style="font-size: 8px;">Qtd: <strong><%= item.quantity %></strong></div>
                        <div style="font-size: 8px; color: #666;">Un: <%= item.unit_price_formatted %></div>
                        <div style="font-size: 10px; font-weight: bold; margin-left: auto;">Total: <%= item.total_price_formatted %></div>
                    </div>
                </div>
            </div>
        </div>
    <% }); %>
</div>

<div style="margin-top: 5px; border-top: 2px solid #000; padding-top: 3px; text-align: right;">
    <div style="font-size: 14px; font-weight: bold;">TOTAL GERAL: <%= total_formatted %></div>
</div>
