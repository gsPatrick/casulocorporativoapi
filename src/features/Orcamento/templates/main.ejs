<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Proposta Comercial #<%= id %></title>
    <style>
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            margin: 0;
            padding: 5px 10px; /* Margens laterais mínimas */
            color: #333;
            background: #fff;
        }
        .container {
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
        }
        .proposta-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .proposta-header h1 {
            font-size: 22px;
            margin: 0;
            color: #000;
            letter-spacing: 1px;
        }
        .box-info {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-top: 20px;
        }
        .info-card {
            flex: 1;
            border: 1px solid #ddd;
            padding: 15px;
            font-size: 11px;
            line-height: 1.6;
        }
        .info-card strong {
            display: block;
            margin-bottom: 5px;
            font-size: 12px;
            color: #000;
        }
        .footer-note {
            margin-top: 40px;
            font-size: 10px;
            color: #888;
            border-top: 1px solid #eee;
            padding-top: 15px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- HEADER COMPONENT -->
        <%- include('components/header') %>

        <div class="proposta-header" style="text-align: center; margin-bottom: 20px;">
            <h1 style="font-size: 18px; margin: 0; color: #000; letter-spacing: 1px; text-transform: uppercase;">PROPOSTA Nº <%= short_code || id.substring(0, 8).toUpperCase() %></h1>
        </div>

        <div style="display: flex; justify-content: space-between; margin-bottom: 15px; font-size: 10px; line-height: 1.4; color: #333;">
            <!-- CLIENT INFO -->
            <div style="border: 1px solid #eee; padding: 12px 15px; flex: 1; margin-right: 15px; line-height: 1.6;">
                <strong style="color: #000; text-transform: uppercase; font-size: 11px; display: block; margin-bottom: 8px; border-bottom: 1px solid #f5f5f5; padding-bottom: 5px;">Para:</strong>
                
                <!-- Identificação -->
                <div style="margin-bottom: 10px;">
                    <% if (customer_name) { %>
                        <span style="font-weight: bold; font-size: 13px; color: #000;"><%= customer_name %></span><br>
                    <% } %>
                    <% if (customer_email || customer_whatsapp) { %>
                        <span style="color: #666; font-size: 10px;">
                            <%= customer_email %> <%= customer_whatsapp ? '| ' + customer_whatsapp : '' %>
                        </span>
                    <% } %>
                </div>

                <!-- Empresa e Documentos -->
                <% if (customer_company || customer_cnpj) { %>
                    <div style="margin-bottom: 10px; border-top: 1px solid #fafafa; padding-top: 5px;">
                        <% if (customer_company) { %>
                            <span style="text-transform: uppercase; font-size: 10px; font-weight: bold;"><%= customer_company %></span><br>
                        <% } %>
                        <% if (customer_cnpj) { %>
                            <span style="color: #444; font-size: 10px;">CNPJ: <%= customer_cnpj %></span>
                        <% } %>
                    </div>
                <% } %>

                <!-- Endereço -->
                <% if (customer_address || customer_cep) { %>
                    <div style="border-top: 1px solid #fafafa; padding-top: 5px;">
                        <span style="color: #666; font-size: 10px;">
                            <%= customer_address %><br>
                            <%= customer_cep ? 'CEP: ' + customer_cep : '' %>
                        </span>
                    </div>
                <% } %>
            </div>

            <!-- PROPOSAL DATA -->
            <div style="border: 1px solid #eee; padding: 10px 12px; width: 220px;">
                <strong style="color: #000; text-transform: uppercase; font-size: 11px; display: block; margin-bottom: 3px;">Dados da Proposta:</strong>
                Data: <%= date %><br>
                Validade: 15 dias<br>
                <% if (vendedor) { %>
                    Consultor: <%= vendedor %>
                <% } %>
            </div>
        </div>

        <!-- ITEMS LIST COMPONENT -->
        <%- include('components/items-table') %>

        <!-- TOTAL AND CONDITIONS (Only this block is kept together) -->
        <div style="page-break-inside: avoid; margin-top: 10px;">
            <!-- CONDITIONS -->
            <div style="margin-top: 15px; font-size: 10px; color: #666; border-top: 1px solid #eee; padding-top: 10px; line-height: 1.4;">
                <strong style="display: block; margin-bottom: 5px; color: #000; text-transform: uppercase;">Condições Gerais:</strong>
                • Preços expressos em Reais (R$).<br>
                • Os prazos de entrega serão confirmados após a aprovação da proposta.<br>
                • Esta proposta está sujeita a análise de crédito.<br>
                • Casulo Indústria e Comércio de Móveis Ltda - Rua Acadêmico Reinaldo Consoni, 681 - Florianópolis, SC.
            </div>

            <% if (termos_contrato) { %>
                <div style="margin-top: 40px; border-top: 2px solid #000; padding-top: 20px; page-break-before: auto;">
                    <div style="margin-bottom: 15px;">
                        <strong style="font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: #000;">
                            Termos e Observações do Contrato
                        </strong>
                    </div>
                    <div style="font-size: 10px; color: #111; line-height: 1.8; text-align: justify; white-space: pre-wrap; padding: 0 15px 20px 15px;">
                        <%= termos_contrato %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
